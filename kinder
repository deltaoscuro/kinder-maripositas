<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kinder Maripositas</title>
    <style>
        /* Estilos base */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Barra de navegación (Navbar) */
        .navbar {
            background-color: #333;
            color: white;
            padding: 10px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
            flex-wrap: wrap;
            position: sticky;
            top: 0;
        }

        .navbar .logo {
            font-size: 24px;
            font-weight: bold;
            color: #ffeb3b;
        }

        .navbar .nav-links {
            display: flex;
            list-style: none;
            align-items: center;
        }

        .navbar .nav-links li {
            margin: 0 15px;
        }

        .navbar .nav-links li a {
            color: white;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .navbar .nav-links li a:hover {
            color: #ffeb3b;
        }

        /* Estilo para el horario en la navbar */
        .horario-navbar {
            background-color: #7b1fa2;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 14px;
            border: 1px solid #ffeb3b;
            color: #ffeb3b;
        }

        /* Contenedor de fondo dividido */
        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
            padding: 40px 0;
            align-items: center;
            min-height: calc(100vh - 120px);
        }

        .fondo-dividido {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            z-index: 1;
        }

        .lado-amarillo {
            flex: 1;
            background-color: #ffeb3b;
        }

        .lado-morado {
            flex: 1;
            background-color: #7b1fa2;
        }

        /* Contenedor del Título + Imagen en el centro */
        .contenido-central {
            position: relative;
            z-index: 5;
            text-align: center;
            width: 90%;
            max-width: 700px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            margin-bottom: 40px;
        }

        .titulo-kinder {
            font-size: 54px;
            color: #333;
            text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.8);
            font-weight: 800;
            text-transform: uppercase;
        }

        .imagen-grande {
            width: 100%;
            height: 350px;
            object-fit: cover;
            border: 10px solid white;
            border-radius: 20px;
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.5);
        }

        /* Sección de la Portada Enlazada */
        .seccion-video {
            display: none;
            width: 100%;
            max-width: 700px;
            position: relative;
            z-index: 5;
            text-align: center;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .seccion-video h2 {
            color: white;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
            font-size: 28px;
        }

        /* Contenedor interactivo de la portada */
        .enlace-portada {
            display: block;
            position: relative;
            width: 100%;
            aspect-ratio: 16 / 9;
            border: 10px solid white;
            border-radius: 20px;
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            cursor: pointer;
        }

        /* Imagen de portada extraída del video real de YouTube */
        .portada-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

        /* Capa oscura que aparece encima de la foto al pasar el mouse */
        .capa-superpuesta {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background-color 0.3s ease;
        }

        /* Icono flotante de Play (Estilo reproductor) */
        .icono-play {
            width: 80px;
            height: 80px;
            background-color: rgba(255, 0, 0, 0.85);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.4);
            transition: transform 0.3s ease, background-color 0.3s ease;
        }

        .icono-play::after {
            content: '';
            display: block;
            width: 0;
            height: 0;
            border-style: solid;
            border-width: 15px 0 15px 25px;
            border-color: transparent transparent transparent white;
            margin-left: 6px; /* Centrado óptico del triángulo */
        }

        /* Efectos Hover (Al pasar el ratón por encima) */
        .enlace-portada:hover .portada-video {
            transform: scale(1.03);
        }

        .enlace-portada:hover .capa-superpuesta {
            background-color: rgba(0, 0, 0, 0.4);
        }

        .enlace-portada:hover .icono-play {
            transform: scale(1.15);
            background-color: rgb(255, 0, 0);
        }

        /* Pie de página (Footer) */
        .footer {
            background-color: #222;
            color: white;
            text-align: center;
            padding: 15px;
            font-size: 14px;
            z-index: 10;
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <div class="logo">🦋 Kinder Maripositas</div>
        <ul class="nav-links">
            <li><a href="#">Inicio</a></li>
            <li><a href="#">Nosotros</a></li>
            <li><a href="#">Grupos</a></li>
            <li><a href="#area-actividades" onclick="mostrarSeccion()">Actividades</a></li>
            <li><a href="#">Contacto</a></li>
            <li class="horario-navbar">
                🕒 Horario: Lunes a Viernes (7:00 am - 11:20 am)
            </li>
        </ul>
    </nav>

    <main class="main-container">
        <div class="fondo-dividido">
            <div class="lado-amarillo"></div>
            <div class="lado-morado"></div>
        </div>

        <div class="contenido-central">
            <h1 class="titulo-kinder">Kinder Maripositas</h1>
            
            <img src="https://images.unsplash.com/photo-1502086223501-7ea6ecd79368?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80" 
                 alt="Educación infantil" 
                 class="imagen-grande">
        </div>

        <div id="area-actividades" class="seccion-video">
            <h2>¡Haz clic en la imagen para ver el video! 🎒</h2>
            
            <a href="https://www.youtube.com/watch?v=P8Bvymudiyg" target="_blank" class="enlace-portada">
                <img src="https://i.ytimg.com/vi/P8Bvymudiyg/maxresdefault.jpg" alt="Portada Video Kinder" class="portada-video">
                <div class="capa-superpuesta">
                    <div class="icono-play"></div>
                </div>
            </a>
        </div>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Kinder Maripositas | "Volando hacia el aprendizaje"</p>
    </footer>

    <script>
        function mostrarSeccion() {
            var x = document.getElementById("area-actividades");
            x.style.display = "block";
        }
    </script>

</body>
</html>
